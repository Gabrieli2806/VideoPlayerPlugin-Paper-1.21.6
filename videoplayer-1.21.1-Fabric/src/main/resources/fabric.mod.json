{
	"schemaVersion": 1,
	"id": "videoplayer",
	"version": "${version}",
	"name": "VideoPlayer",
	"description": "All-in-one Fabric mod: server-side cinematic commands, client video playback (HUD + Block display), video registry and more.",
	"authors": [
		"g2806"
	],
	"contact": {
		"homepage": "https://example.invalid",
		"sources": "https://example.invalid"
	},
	"license": "CC0-1.0",
	"icon": "assets/videoplayer/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.g2806.videoplayer.VideoPlayer"
		],
		"client": [
			"com.g2806.videoplayer.VideoPlayerClient"
		]
	},
	"mixins": [
		"videoplayer.mixins.json",
		{
			"config": "videoplayer.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}